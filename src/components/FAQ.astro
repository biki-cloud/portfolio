---
const faqs = [
  {
    q: '費用はどのくらいかかりますか？',
    a: 'ライト版が初期3万円・月額3,000円、フル版が初期5万円・月額5,000円です。初案件限定のモニター価格（初期1万円）もご用意しています。ドメイン代（年1,000〜2,000円）は実費別途となります。',
  },
  {
    q: '納期はどのくらいですか？',
    a: '素材（写真・テキスト）をいただいてから、おおよそ2〜3週間での納品を予定しています。',
  },
  {
    q: '写真や文章は自分で用意する必要がありますか？',
    a: '施工写真はお客様にご用意いただきます。文章はヒアリングをもとに制作側でご提案することも可能です。',
  },
  {
    q: '公開後に自分でサイトを更新できますか？',
    a: 'フル版ではMicroCMSを採用しており、施工事例やお知らせを管理画面から簡単に更新できます。ライト版は更新が必要な場合は月額保守内で対応します。',
  },
  {
    q: 'スマホでも見られますか？',
    a: 'はい。全テンプレートがスマートフォン・タブレット・PCに対応したレスポンシブデザインです。',
  },
];
---
<section id="faq" class="py-24 px-6" style="background-color: var(--color-bg);">
  <div class="max-w-3xl mx-auto">
    <div class="text-center mb-16 reveal">
      <p class="text-xs tracking-[0.3em] uppercase mb-4" style="color: var(--color-accent);">FAQ</p>
      <h2 class="text-3xl font-bold section-title section-title-center" style="color: var(--color-dark);">よくある質問</h2>
    </div>

    <div class="space-y-3">
      {faqs.map((faq, i) => (
        <details class={`faq-item reveal reveal-delay-${Math.min(i + 1, 4)}`} style="background-color: var(--color-surface);">
          <summary class="faq-summary px-6 py-5 cursor-pointer font-semibold flex justify-between items-center gap-4" style="color: var(--color-dark);">
            <span>Q. {faq.q}</span>
            <span class="faq-icon flex-shrink-0 w-5 h-5 flex items-center justify-center" style="color: var(--color-warm);">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 6l5 5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
          </summary>
          <div class="faq-body px-6 pb-5">
            <p class="text-sm leading-relaxed pt-2" style="color: var(--color-sub); border-top: 1px solid var(--color-border);">A. {faq.a}</p>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
.faq-item {
  overflow: hidden;
  transition: box-shadow 0.2s ease;
}
.faq-item:hover {
  box-shadow: 0 2px 12px rgba(15, 24, 41, 0.07);
}
.faq-summary {
  list-style: none;
  user-select: none;
}
.faq-summary::-webkit-details-marker { display: none; }
.faq-icon {
  transition: transform 0.3s ease;
}
details[open] .faq-icon {
  transform: rotate(180deg);
}
.faq-body {
  animation: faq-open 0.25s ease-out;
}
@keyframes faq-open {
  from { opacity: 0; transform: translateY(-6px); }
  to   { opacity: 1; transform: translateY(0); }
}
</style>
