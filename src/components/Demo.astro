---
---
<section class="py-24 px-6" style="background-color: var(--color-bg);">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-16 reveal">
      <p class="text-xs tracking-[0.3em] uppercase mb-4" style="color: var(--color-accent);">Works</p>
      <h2 class="text-3xl font-bold section-title section-title-center" style="color: var(--color-dark);">制作デモ</h2>
      <p class="mt-6 text-sm" style="color: var(--color-sub);">実際に動くデモサイトをご覧いただけます</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <!-- ライト版 -->
      <div class="reveal">
        <div class="overflow-hidden mb-4" style="background-color: var(--color-border); aspect-ratio: 16/10;">
          <img src="/demo-light.png" alt="ライト版デモ" class="w-full h-full object-cover object-top"
            onerror="this.parentElement.style.display='flex';this.parentElement.style.alignItems='center';this.parentElement.style.justifyContent='center';this.style.display='none';this.insertAdjacentHTML('afterend','<p style=\'color:var(--color-sub);font-size:0.75rem;letter-spacing:0.2em;\'>スクリーンショット準備中</p>')" />
        </div>
        <h3 class="text-lg font-semibold mb-1" style="color: var(--color-dark);">ライト版</h3>
        <p class="text-sm mb-3" style="color: var(--color-sub);">1ページLP・シンプル構成</p>
        <a
          href="https://template-exterior-lite.pages.dev"
          target="_blank"
          rel="noopener"
          class="text-sm tracking-widest border px-5 py-2 inline-block transition-opacity hover:opacity-70"
          style="border-color: var(--color-accent); color: var(--color-accent);"
        >
          デモを見る →
        </a>
      </div>

      <!-- フル版 -->
      <div class="reveal reveal-delay-2">
        <div class="overflow-hidden mb-4" style="background-color: var(--color-border); aspect-ratio: 16/10;">
          <img src="/demo-full.png" alt="フル版デモ" class="w-full h-full object-cover object-top"
            onerror="this.parentElement.style.display='flex';this.parentElement.style.alignItems='center';this.parentElement.style.justifyContent='center';this.style.display='none';this.insertAdjacentHTML('afterend','<p style=\'color:var(--color-sub);font-size:0.75rem;letter-spacing:0.2em;\'>スクリーンショット準備中</p>')" />
        </div>
        <h3 class="text-lg font-semibold mb-1" style="color: var(--color-dark);">フル版</h3>
        <p class="text-sm mb-3" style="color: var(--color-sub);">MicroCMS付き・フルページ構成</p>
        <a
          href="https://template-exterior.pages.dev"
          target="_blank"
          rel="noopener"
          class="text-sm tracking-widest border px-5 py-2 inline-block transition-opacity hover:opacity-70"
          style="border-color: var(--color-accent); color: var(--color-accent);"
        >
          デモを見る →
        </a>
      </div>
    </div>
  </div>
</section>
