---
---
<section class="py-24 px-6" style="background-color: var(--color-bg);">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-16 reveal">
      <p class="text-xs tracking-[0.3em] uppercase mb-4" style="color: var(--color-accent);">Demo</p>
      <h2 class="text-3xl font-bold section-title section-title-center" style="color: var(--color-dark);">制作デモ</h2>
      <p class="mt-6 text-sm" style="color: var(--color-sub);">実際に動くデモサイトをご覧いただけます</p>
    </div>

    <!-- デモカード -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-24">
      <!-- ライト版 -->
      <div class="reveal">
        <div class="overflow-hidden mb-4 relative" style="aspect-ratio: 16/10; background-color: var(--color-border);">
          <iframe
            src="https://template-exterior-lite.pages.dev"
            style="width: 200%; height: 200%; border: none; pointer-events: none; transform: scale(0.5); transform-origin: top left;"
            loading="lazy"
            title="ライト版デモ"
          ></iframe>
        </div>
        <div class="flex items-center gap-2 mb-1">
          <h3 class="text-lg font-semibold" style="color: var(--color-dark);">ライト版</h3>
          <span class="text-xs px-2 py-0.5 font-medium" style="background-color: #faeee8; color: #c0522a;">テラコッタ</span>
        </div>
        <p class="text-sm mb-3" style="color: var(--color-sub);">1ページLP・シンプル構成</p>
        <a
          href="https://template-exterior-lite.pages.dev"
          target="_blank"
          rel="noopener"
          class="text-sm tracking-widest border px-5 py-2 inline-block transition-opacity hover:opacity-70"
          style="border-color: var(--color-accent); color: var(--color-accent);"
        >
          デモを見る →
        </a>
      </div>

      <!-- フル版 -->
      <div class="reveal reveal-delay-2">
        <div class="overflow-hidden mb-4 relative" style="aspect-ratio: 16/10; background-color: var(--color-border);">
          <iframe
            src="https://template-exterior.pages.dev"
            style="width: 200%; height: 200%; border: none; pointer-events: none; transform: scale(0.5); transform-origin: top left;"
            loading="lazy"
            title="フル版デモ"
          ></iframe>
        </div>
        <div class="flex items-center gap-2 mb-1">
          <h3 class="text-lg font-semibold" style="color: var(--color-dark);">フル版</h3>
          <span class="text-xs px-2 py-0.5 font-medium" style="background-color: var(--color-warm-lt); color: var(--color-accent);">グリーン</span>
        </div>
        <p class="text-sm mb-3" style="color: var(--color-sub);">多ページ・CMS連携・施工事例管理</p>
        <a
          href="https://template-exterior.pages.dev"
          target="_blank"
          rel="noopener"
          class="text-sm tracking-widest border px-5 py-2 inline-block transition-opacity hover:opacity-70"
          style="border-color: var(--color-accent); color: var(--color-accent);"
        >
          デモを見る →
        </a>
      </div>
    </div>

    <!-- プラン全機能比較表 -->
    <div class="reveal">
      <div class="text-center mb-10">
        <p class="text-xs tracking-[0.3em] uppercase mb-3" style="color: var(--color-accent);">Plan Comparison</p>
        <h3 class="text-2xl font-bold" style="color: var(--color-dark);">プラン詳細比較</h3>
        <p class="text-sm mt-3" style="color: var(--color-sub);">できること・できないことを全て記載しています</p>
      </div>

      <!-- プランヘッダー（固定） -->
      <div class="overflow-x-auto">
        <table class="w-full text-sm" style="border-collapse: collapse; min-width: 480px;">
          <thead>
            <tr>
              <th class="py-5 text-left pl-4" style="width: 52%; background-color: var(--color-surface);"></th>
              <!-- ライト版 -->
              <th class="py-5 px-4 text-center" style="width: 24%; background-color: #faeee8;">
                <p class="text-xs tracking-widest uppercase mb-1" style="color: #c0522a;">Light</p>
                <p class="text-base font-bold" style="color: #1f1208;">ライト版</p>
                <p class="text-xs mt-1 font-normal" style="color: #8a7060;">3万円〜 / 月3,000円</p>
              </th>
              <!-- フル版 -->
              <th class="py-5 px-4 text-center" style="width: 24%; background-color: var(--color-accent);">
                <p class="text-xs tracking-widest uppercase mb-1 text-white opacity-70">Full</p>
                <p class="text-base font-bold text-white">フル版</p>
                <p class="text-xs mt-1 font-normal text-white opacity-70">5万円〜 / 月5,000円</p>
              </th>
            </tr>
          </thead>
          <tbody>

            {/* ── 料金 ── */}
            <tr style="background-color: var(--color-border);">
              <td colspan={3} class="py-2 pl-4 text-xs font-bold tracking-widest uppercase" style="color: var(--color-sub);">料金</td>
            </tr>
            {[
              { label: '初期費用',     lite: '30,000円〜', full: '50,000円〜' },
              { label: '月額保守',     lite: '3,000円/月', full: '5,000円/月' },
              { label: 'ドメイン代',   lite: '実費別途（年1,000〜2,000円）', full: '実費別途（年1,000〜2,000円）' },
            ].map((row, i) => (
              <tr style={`border-bottom: 1px solid var(--color-border); background-color: ${i % 2 === 0 ? 'var(--color-surface)' : 'transparent'};`}>
                <td class="py-3 pl-4 font-medium" style="color: var(--color-text);">{row.label}</td>
                <td class="py-3 px-4 text-center" style="color: var(--color-sub);">{row.lite}</td>
                <td class="py-3 px-4 text-center" style="color: var(--color-sub);">{row.full}</td>
              </tr>
            ))}

            {/* ── ページ構成 ── */}
            <tr style="background-color: var(--color-border);">
              <td colspan={3} class="py-2 pl-4 text-xs font-bold tracking-widest uppercase" style="color: var(--color-sub);">ページ構成</td>
            </tr>
            {[
              { label: 'トップページ',               lite: true,  full: true  },
              { label: '施工事例一覧ページ',         lite: false, full: true  },
              { label: '施工事例詳細ページ',         lite: false, full: true  },
              { label: 'お知らせ一覧・詳細',         lite: false, full: true  },
              { label: '会社概要・サービス・流れ',   lite: false, full: true  },
              { label: 'お問い合わせページ',         lite: false, full: true  },
            ].map((row, i) => (
              <tr style={`border-bottom: 1px solid var(--color-border); background-color: ${i % 2 === 0 ? 'var(--color-surface)' : 'transparent'};`}>
                <td class="py-3 pl-4 font-medium" style="color: var(--color-text);">{row.label}</td>
                <td class="py-3 px-4 text-center text-base">{row.lite ? <span style="color: var(--color-warm);">✓</span> : <span class="opacity-30" style="color: var(--color-text);">✗</span>}</td>
                <td class="py-3 px-4 text-center text-base">{row.full ? <span style="color: var(--color-warm);">✓</span> : <span class="opacity-30" style="color: var(--color-text);">✗</span>}</td>
              </tr>
            ))}

            {/* ── 制作時カスタマイズ ── */}
            <tr style="background-color: var(--color-border);">
              <td colspan={3} class="py-2 pl-4 text-xs font-bold tracking-widest uppercase" style="color: var(--color-sub);">制作時カスタマイズ（納品前に設定）</td>
            </tr>
            {[
              { label: '会社名・キャッチコピー',           lite: true,  full: true  },
              { label: 'メインカラー・背景色',             lite: true,  full: true  },
              { label: '対応エリア・電話番号',             lite: true,  full: true  },
              { label: 'ヒーロー背景画像',                 lite: true,  full: true  },
              { label: '施工事例写真（初期6枚）',          lite: true,  full: true  },
              { label: 'お客様の声（初期3件）',            lite: true,  full: true  },
              { label: 'Favicon（タブのアイコン）',        lite: true,  full: true  },
              { label: 'SNSリンク（Instagram等）',         lite: true,  full: true  },
              { label: 'Google Analytics設定',             lite: true,  full: true  },
              { label: 'Google Formsお問い合わせ連携',     lite: true,  full: true  },
            ].map((row, i) => (
              <tr style={`border-bottom: 1px solid var(--color-border); background-color: ${i % 2 === 0 ? 'var(--color-surface)' : 'transparent'};`}>
                <td class="py-3 pl-4 font-medium" style="color: var(--color-text);">{row.label}</td>
                <td class="py-3 px-4 text-center text-base">{row.lite ? <span style="color: var(--color-warm);">✓</span> : <span class="opacity-30" style="color: var(--color-text);">✗</span>}</td>
                <td class="py-3 px-4 text-center text-base">{row.full ? <span style="color: var(--color-warm);">✓</span> : <span class="opacity-30" style="color: var(--color-text);">✗</span>}</td>
              </tr>
            ))}

            {/* ── 変更できないこと ── */}
            <tr style="background-color: var(--color-border);">
              <td colspan={3} class="py-2 pl-4 text-xs font-bold tracking-widest uppercase" style="color: var(--color-sub);">変更できないこと</td>
            </tr>
            {[
              { label: 'レイアウト・デザイン構成',   lite: false, full: false },
              { label: 'フォント',                   lite: false, full: false },
              { label: 'セクションの追加・削除',     lite: false, full: false },
              { label: 'ページの追加',               lite: false, full: false },
            ].map((row, i) => (
              <tr style={`border-bottom: 1px solid var(--color-border); background-color: ${i % 2 === 0 ? 'var(--color-surface)' : 'transparent'};`}>
                <td class="py-3 pl-4 font-medium" style="color: var(--color-text);">{row.label}</td>
                <td class="py-3 px-4 text-center text-base"><span class="opacity-30" style="color: var(--color-text);">✗</span></td>
                <td class="py-3 px-4 text-center text-base"><span class="opacity-30" style="color: var(--color-text);">✗</span></td>
              </tr>
            ))}

            {/* ── 運用中の自己更新 ── */}
            <tr style="background-color: var(--color-border);">
              <td colspan={3} class="py-2 pl-4 text-xs font-bold tracking-widest uppercase" style="color: var(--color-sub);">運用中の自己更新（CMS）</td>
            </tr>
            {[
              { label: '施工事例の追加・編集', lite: false, full: true  },
              { label: 'お知らせの追加・編集', lite: false, full: true  },
            ].map((row, i) => (
              <tr style={`border-bottom: 1px solid var(--color-border); background-color: ${i % 2 === 0 ? 'var(--color-surface)' : 'transparent'};`}>
                <td class="py-3 pl-4 font-medium" style="color: var(--color-text);">{row.label}</td>
                <td class="py-3 px-4 text-center text-base">{row.lite ? <span style="color: var(--color-warm);">✓</span> : <span class="opacity-30" style="color: var(--color-text);">✗</span>}</td>
                <td class="py-3 px-4 text-center text-base">{row.full ? <span style="color: var(--color-warm);">✓</span> : <span class="opacity-30" style="color: var(--color-text);">✗</span>}</td>
              </tr>
            ))}

            {/* ── 月額保守内容 ── */}
            <tr style="background-color: var(--color-border);">
              <td colspan={3} class="py-2 pl-4 text-xs font-bold tracking-widest uppercase" style="color: var(--color-sub);">月額保守内容</td>
            </tr>
            {[
              { label: 'サーバー・ドメイン維持管理',       lite: true,  full: true  },
              { label: '軽微なテキスト修正',               lite: true,  full: true  },
              { label: '施工事例写真の差し替え',           lite: '月1回まで', full: '自己更新（CMS）' },
              { label: 'セキュリティ・速度維持',           lite: true,  full: true  },
            ].map((row, i) => (
              <tr style={`border-bottom: 1px solid var(--color-border); background-color: ${i % 2 === 0 ? 'var(--color-surface)' : 'transparent'};`}>
                <td class="py-3 pl-4 font-medium" style="color: var(--color-text);">{row.label}</td>
                <td class="py-3 px-4 text-center" style="color: var(--color-sub);">
                  {typeof row.lite === 'boolean'
                    ? (row.lite ? <span class="text-base" style="color: var(--color-warm);">✓</span> : <span class="text-base opacity-30" style="color: var(--color-text);">✗</span>)
                    : row.lite}
                </td>
                <td class="py-3 px-4 text-center" style="color: var(--color-sub);">
                  {typeof row.full === 'boolean'
                    ? (row.full ? <span class="text-base" style="color: var(--color-warm);">✓</span> : <span class="text-base opacity-30" style="color: var(--color-text);">✗</span>)
                    : row.full}
                </td>
              </tr>
            ))}

            {/* ── こんな方に ── */}
            <tr style="background-color: var(--color-accent);">
              <td class="py-4 pl-4 text-xs font-bold tracking-widest uppercase text-white opacity-70">こんな方に</td>
              <td class="py-4 px-4 text-center text-sm font-semibold" style="color: #1f1208; background-color: #faeee8;">まずHPが欲しい方</td>
              <td class="py-4 px-4 text-center text-sm font-semibold text-white">施工事例で集客したい方</td>
            </tr>

          </tbody>
        </table>
      </div>

      <p class="text-xs text-center mt-6" style="color: var(--color-sub);">※ ドメイン代（年1,000〜2,000円）は実費別途となります</p>
    </div>

  </div>
</section>
